<div class="bg-white shadow rounded-lg p-6" id="widget_<%= widget.id %>" data-widget-id="<%= widget.id %>">
  <div class="flex justify-between items-start mb-4">
    <h3 class="text-lg font-medium text-gray-900"><%= widget.title %></h3>
    <div class="flex space-x-2">
      <% if widget.pending? %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
          Pendiente
        </span>
      <% elsif widget.approved? %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
          Aprobado
        </span>
      <% elsif widget.rejected? %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
          Rechazado
        </span>
      <% end %>
    </div>
  </div>

  <div class="mb-4">
    <p class="text-sm text-gray-600 mb-2">
      <strong>Consulta:</strong> <%= widget.natural_query %>
    </p>
  </div>

  <% if widget.sql_query.present? %>
    <div class="mb-4">
      <h4 class="text-sm font-medium text-gray-700 mb-2">SQL Generado:</h4>
      <pre class="bg-gray-50 p-3 rounded text-sm overflow-x-auto"><code><%= widget.sql_query %></code></pre>
    </div>
  <% end %>

  <div class="flex justify-between items-center">
    <div class="flex space-x-2">
      <% if widget.pending? && widget.sql_query.present? %>
        <%= link_to "✓ Aprobar", approve_dashboard_dashboard_widget_path(widget.dashboard, widget),
            method: :patch,
            data: { turbo_method: :patch },
            class: "text-green-600 hover:text-green-900 text-sm font-medium" %>
        <%= link_to "✗ Rechazar", reject_dashboard_dashboard_widget_path(widget.dashboard, widget),
            method: :patch,
            data: { turbo_method: :patch },
            class: "text-red-600 hover:text-red-900 text-sm font-medium" %>
      <% elsif widget.approved? %>
        <%= link_to "Ejecutar", execute_dashboard_dashboard_widget_path(widget.dashboard, widget),
            method: :post,
            data: { turbo_method: :post },
            class: "text-blue-600 hover:text-blue-900 text-sm font-medium" %>
      <% end %>
      
      <% if widget.chart_type.present? %>
        <span class="text-gray-500 text-sm">Gráfico: <%= widget.chart_type.titleize %></span>
      <% end %>
    </div>

    <div class="flex space-x-2">
      <%= link_to "Regenerar SQL", regenerate_sql_dashboard_dashboard_widget_path(widget.dashboard, widget),
          method: :post,
          data: { turbo_method: :post },
          class: "text-gray-600 hover:text-gray-900 text-sm font-medium" %>
      <%= link_to "Eliminar", dashboard_dashboard_widget_path(widget.dashboard, widget),
          method: :delete,
          data: { 
            confirm: "¿Estás seguro?",
            turbo_method: :delete
          },
          class: "text-red-600 hover:text-red-900 text-sm font-medium" %>
    </div>
  </div>

  <!-- Área para mostrar resultados -->
  <div id="widget-results-<%= widget.id %>" class="mt-4">
    <% if widget.approved? && widget.can_execute? %>
      <% begin %>
        <% results = execute_widget_query(widget) %>
        <% if results.present? %>
          
          <!-- Chart type selector - Más prominente -->
          <div class="mb-4 bg-white border border-gray-200 rounded-lg p-3 shadow-sm">
            <div class="flex items-center justify-between mb-3">
              <h4 class="text-sm font-medium text-gray-800">📊 Visualización</h4>
              <span class="text-xs text-gray-500"><%= pluralize(results.length, 'registro') %></span>
            </div>
            
            <!-- Botones de tipo de gráfico más visuales -->
            <div class="flex flex-wrap gap-2">
              <button type="button" 
                      onclick="updateChart(<%= widget.id %>, 'table')"
                      id="btn-table-<%= widget.id %>"
                      class="chart-type-btn px-3 py-2 text-xs font-medium rounded-md border transition-colors duration-200
                             <%= widget.chart_type == 'table' || widget.chart_type.blank? ? 
                                 'bg-blue-100 border-blue-300 text-blue-800' : 
                                 'bg-gray-50 border-gray-200 text-gray-600 hover:bg-gray-100' %>">
                📋 Tabla
              </button>
              
              <button type="button" 
                      onclick="updateChart(<%= widget.id %>, 'bar')"
                      id="btn-bar-<%= widget.id %>"
                      class="chart-type-btn px-3 py-2 text-xs font-medium rounded-md border transition-colors duration-200
                             <%= widget.chart_type == 'bar' ? 
                                 'bg-blue-100 border-blue-300 text-blue-800' : 
                                 'bg-gray-50 border-gray-200 text-gray-600 hover:bg-gray-100' %>">
                📊 Barras
              </button>
              
              <button type="button" 
                      onclick="updateChart(<%= widget.id %>, 'line')"
                      id="btn-line-<%= widget.id %>"
                      class="chart-type-btn px-3 py-2 text-xs font-medium rounded-md border transition-colors duration-200
                             <%= widget.chart_type == 'line' ? 
                                 'bg-blue-100 border-blue-300 text-blue-800' : 
                                 'bg-gray-50 border-gray-200 text-gray-600 hover:bg-gray-100' %>">
                📈 Línea
              </button>
              
              <button type="button" 
                      onclick="updateChart(<%= widget.id %>, 'pie')"
                      id="btn-pie-<%= widget.id %>"
                      class="chart-type-btn px-3 py-2 text-xs font-medium rounded-md border transition-colors duration-200
                             <%= widget.chart_type == 'pie' ? 
                                 'bg-blue-100 border-blue-300 text-blue-800' : 
                                 'bg-gray-50 border-gray-200 text-gray-600 hover:bg-gray-100' %>">
                🥧 Circular
              </button>
              
              <button type="button" 
                      onclick="updateChart(<%= widget.id %>, 'area')"
                      id="btn-area-<%= widget.id %>"
                      class="chart-type-btn px-3 py-2 text-xs font-medium rounded-md border transition-colors duration-200
                             <%= widget.chart_type == 'area' ? 
                                 'bg-blue-100 border-blue-300 text-blue-800' : 
                                 'bg-gray-50 border-gray-200 text-gray-600 hover:bg-gray-100' %>">
                🏔️ Área
              </button>
            </div>
          </div>
          
          <!-- Contenedor de datos -->
          <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
            
            <!-- Data table -->
            <div id="table-<%= widget.id %>" style="<%= 'display: none;' if widget.chart_type.present? && widget.chart_type != 'table' %>">
              <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                  <thead class="bg-gray-50">
                    <tr>
                      <% results.first.keys.each do |header| %>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                          <%= header %>
                        </th>
                      <% end %>
                    </tr>
                  </thead>
                  <tbody class="bg-white divide-y divide-gray-200">
                    <% results.each do |row| %>
                      <tr>
                        <% row.values.each do |value| %>
                          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            <%= value %>
                          </td>
                        <% end %>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
            
            <!-- Chart canvas -->
            <canvas id="chart-<%= widget.id %>" width="400" height="200" 
                    style="<%= 'display: none;' if widget.chart_type.blank? || widget.chart_type == 'table' %>"></canvas>
          </div>
          
          <script>
            // Auto-render chart when page loads
            document.addEventListener('DOMContentLoaded', function() {
              const chartType = '<%= widget.chart_type || "table" %>';
              if (chartType !== 'table') {
                setTimeout(() => updateChart(<%= widget.id %>, chartType), 100);
              }
            });
          </script>
        <% end %>
      <% rescue => e %>
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
          <p class="text-sm text-red-800">Error al cargar datos: <%= e.message %></p>
        </div>
      <% end %>
    <% else %>
      <!-- Mensajes de estado más claros y amigables -->
      <div class="text-center py-8 bg-gray-50 rounded-lg border-2 border-dashed border-gray-200">
        <% if widget.pending? %>
          <div class="text-yellow-600">
            ⏳ <span class="font-medium">Esperando aprobación</span>
            <p class="text-sm text-gray-600 mt-1">Revisa el SQL generado y apruébalo para ver los datos</p>
          </div>
        <% elsif widget.rejected? %>
          <div class="text-red-600">
            ❌ <span class="font-medium">Widget rechazado</span>
            <p class="text-sm text-gray-600 mt-1">Regenera el SQL o modifica la consulta</p>
          </div>
        <% elsif widget.approved? && !widget.can_execute? %>
          <div class="text-gray-600">
            ⚠️ <span class="font-medium">Sin SQL para ejecutar</span>
            <p class="text-sm text-gray-500 mt-1">Regenera el SQL para ver los datos</p>
          </div>
        <% else %>
          <div class="text-gray-600">
            📋 <span class="font-medium">Widget sin configurar</span>
            <p class="text-sm text-gray-500 mt-1">Completa la configuración para ver los datos</p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>